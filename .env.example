# ── Sidra Media configuration ───────────────────────────────────────
# Copy to .env and adjust. A single app, a single SQLite file.

# Secret used to sign login session cookies (JWT). CHANGE THIS.
AUTH_SECRET=change-me-to-a-long-random-string

# SQLite database file. Relative paths are resolved from the prisma/ dir.
# In Docker this is set to an absolute path on a mounted volume.
DATABASE_URL="file:./dev.db"

# First-run admin account (created by the seed script if no admin exists).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@sidra.local

# ── Media folders ───────────────────────────────────────────────────
# Where downloaded videos/audio are saved.
DOWNLOAD_VIDEO_PATH=./media/downloads/videos
DOWNLOAD_AUDIO_PATH=./media/downloads/audio

# Existing libraries to browse & stream (your NAS "Media" folders).
# Comma-separate multiple folders if you like.
MEDIA_VIDEO_PATH=./media/library/videos
MEDIA_AUDIO_PATH=./media/library/music

# Directory for generated thumbnails (cache).
THUMBNAIL_CACHE_DIR=./media/.thumbnails

# Absolute paths to binaries (leave blank to use PATH).
YTDLP_PATH=
FFMPEG_PATH=
FFPROBE_PATH=
